<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Surprise for Daksh 💖</title>
  <link rel="stylesheet" href="style.css">
</head>

<body>

<!-- BACKGROUND CANVAS -->
<canvas id="sky"></canvas>

<!-- PASSWORD SCREEN 1 -->
<div id="lockScreen1" class="screen">
  <h1>🔒 Enter Password</h1>
  <input type="password" id="pass1" placeholder="Enter password">
  <button onclick="checkPass1()">Unlock</button>
</div>

<!-- MAIN BIRTHDAY SCREEN -->
<div id="mainScreen" class="hidden">

  <h1 class="title">🎉 Happy Birthday Daksh 🎉</h1>
  <p class="subtitle">This one is special... hope you know why 💖</p>

  <button onclick="blowCandle()">🕯️ Blow Candle</button>
  <button onclick="cutCake()">🎂 Cut Cake</button>

  <div id="confetti"></div>

  <h2>🎮 Game Zone (Earn Kiss Rewards 💋)</h2>
  <div class="grid">

    <button onclick="openGame('ttt')">Tic Tac Toe</button>
    <button onclick="openGame('snake')">Snake Game</button>
    <button onclick="openGame('memory')">Memory Match</button>
    <button onclick="openGame('rps')">Rock Paper Scissors</button>
    <button onclick="openGame('guess')">Number Guess</button>
    <button onclick="openGame('trivia')">Birthday Trivia</button>

    <button onclick="openGame('others')">More Games</button>

  </div>

  <h2>💌 Special Note (Locked)</h2>
  <input type="password" id="notePass" placeholder="Note password">
  <button onclick="openNote()">Unlock Note</button>

  <div id="note" class="hidden">
    <p>
      Happiest Birthday to the person who is the reason for my happiness 💖<br><br>
      I promise I will not throw tantrums or annoy you this month 😌<br><br>
      From: Ms. Bishnoi<br>
      To: Daksh
    </p>
  </div>

  <h2>🌹 Flowers + Fireworks</h2>
  <button onclick="startFireworks()">🎆 Start Fireworks</button>
  <div id="flowers">💐💐💐💐💐</div>

  <h2>🎵 Music</h2>
  <iframe width="300" height="200"
    src="https://www.youtube.com/embed/videoseries?list=PLy32nUMhA3riuWTxvIFuI29GSuysi2snd"
    allowfullscreen>
  </iframe>

  <h2>💋 Kiss Rewards</h2>
  <p id="kissCount">Kisses: 0 💋</p>

</div>

<!-- GAME MODAL -->
<div id="gameModal" class="hidden">
  <div id="gameContent"></div>
  <button onclick="closeGame()">Close</button>
</div>

<script src="script.js"></script>
</body>
</html>
style.css
body {
  margin: 0;
  font-family: Arial;
  background: linear-gradient(120deg, #ffd6e0, #d6f5ff, #e6d6ff);
  color: #333;
  text-align: center;
}

.hidden { display: none; }

.screen {
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.title {
  font-size: 40px;
}

.subtitle {
  font-size: 18px;
}

button {
  padding: 10px;
  margin: 5px;
  border-radius: 10px;
  border: none;
  background: #ffb6c1;
  cursor: pointer;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  width: 300px;
  margin: auto;
  gap: 10px;
}

#gameModal {
  position: fixed;
  top: 10%;
  left: 20%;
  width: 60%;
  background: white;
  padding: 20px;
  border-radius: 20px;
}

canvas {
  position: fixed;
  top: 0;
  left: 0;
  z-index: -1;
}
script.js
let kisses = 0;

function checkPass1() {
  let p = document.getElementById("pass1").value;
  if (p === "MINE") {
    document.getElementById("lockScreen1").style.display = "none";
    document.getElementById("mainScreen").classList.remove("hidden");
  } else {
    alert("Wrong Password 💔");
  }
}

/* NOTE PASSWORD */
function openNote() {
  let p = document.getElementById("notePass").value;
  if (p === "28/10/10") {
    document.getElementById("note").classList.remove("hidden");
    addKiss(2);
  } else {
    alert("Wrong password!");
  }
}

/* CAKE + CANDLE */
function blowCandle() {
  alert("🕯️ Candle blown!");
  triggerConfetti();
}

function cutCake() {
  alert("🎂 Cake cut!");
  triggerConfetti();
  addKiss(5);
}

/* CONFETTI */
function triggerConfetti() {
  let c = document.getElementById("confetti");
  c.innerHTML = "🎉🎉🎉🎉🎉🎉🎉";
}

/* KISS SYSTEM */
function addKiss(n) {
  kisses += n;
  document.getElementById("kissCount").innerText = "Kisses: " + kisses + " 💋";
}

/* GAME MODAL */
function openGame(type) {
  let g = document.getElementById("gameModal");
  let c = document.getElementById("gameContent");

  g.classList.remove("hidden");

  if (type === "rps") {
    c.innerHTML = `
      <h3>Rock Paper Scissors</h3>
      <button onclick="rps('rock')">Rock</button>
      <button onclick="rps('paper')">Paper</button>
      <button onclick="rps('scissors')">Scissors</button>
      <p id="rpsResult"></p>
    `;
  }

  if (type === "guess") {
    c.innerHTML = `
      <h3>Number Guess (1-5)</h3>
      <input id="guessInput">
      <button onclick="guess()">Try</button>
      <p id="guessResult"></p>
    `;
  }

  if (type === "ttt") {
    c.innerHTML = `<h3>Tic Tac Toe (simple)</h3><p>Upgrade version needed for full AI</p>`;
  }

  if (type === "snake") {
    c.innerHTML = `<h3>Snake Game</h3><p>Canvas version can be upgraded</p>`;
  }

  if (type === "memory") {
    c.innerHTML = `<h3>Memory Game</h3><p>Flip cards version can be added</p>`;
  }

  if (type === "trivia") {
    c.innerHTML = `
      <h3>Birthday Trivia</h3>
      <p>Q: Who is special today?</p>
      <button onclick="trivia(true)">Daksh</button>
      <button onclick="trivia(false)">Someone else</button>
      <p id="triviaRes"></p>
    `;
  }
}

/* SIMPLE GAME LOGIC */
function rps(choice) {
  let arr = ["rock","paper","scissors"];
  let bot = arr[Math.floor(Math.random()*3)];
  let res = "";

  if (choice === bot) res = "Draw!";
  else if (
    (choice==="rock" && bot==="scissors") ||
    (choice==="paper" && bot==="rock") ||
    (choice==="scissors" && bot==="paper")
  ) {
    res = "You Win! +2 💋";
    addKiss(2);
  } else {
    res = "You Lose!";
  }

  document.getElementById("rpsResult").innerText = res;
}

function guess() {
  let num = Math.floor(Math.random()*5)+1;
  let g = document.getElementById("guessInput").value;

  if (parseInt(g) === num) {
    document.getElementById("guessResult").innerText = "Correct! +3 💋";
    addKiss(3);
  } else {
    document.getElementById("guessResult").innerText = "Wrong! It was " + num;
  }
}

function trivia(ans) {
  if (ans) {
    document.getElementById("triviaRes").innerText = "Correct 💖 +2 💋";
    addKiss(2);
  } else {
    document.getElementById("triviaRes").innerText = "Wrong!";
  }
}

function closeGame() {
  document.getElementById("gameModal").classList.add("hidden");
}

/* FIREWORKS BACKGROUND (simple) */
function startFireworks() {
  alert("🎆 Fireworks started!");
}
